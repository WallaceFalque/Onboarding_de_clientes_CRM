@page "/criarUnboarding"
@using Onboarding_de_clientes_CRM.Data
@inject ApplicationDbContext db
@using Onboarding_de_clientes_CRM.Models
@rendermode InteractiveServer

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-12 text-center text-md-start">
            <h3 class="fw-bold text-dark mb-1">
                <i class="bi bi-people-fill text-primary me-2"></i>Gestão de Projetos
            </h3>
            <p class="text-muted">Cadastre novos projetos e gerencie sua base de unboardings com facilidade.</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 custom-card">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h5 class="fw-bold m-0"><i class="bi bi-plus-circle me-2 text-primary"></i>Novo Unboarding</h5>
                    </div>
                    <div class="card-body p-4">
                       
                        <div class="row g-4">

                            <div class="col-md-8">
                                <label class="form-label fw-semibold">Nome do Projeto</label>
                                <input class="form-control" @bind="novoOnboarding" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Prioridade</label>
                                <select class="form-select">
                                   
                                    @foreach (var opcoes in Enum.GetValues<PrioridadeOnboarding>())
                              
                                    {
                                        <option selected value="@opcoes">@opcoes</option>
                                    }
                                    <option selected disabled>Selecione</option>
                                </select>
                                
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Data de Início</label>
                                <input class="form-control" @bind="dataInicio" type="date" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Tem prazo final?</label>
                                <select class="form-select" id="temPrazo">
                                    <option selected disabled>Selecione</option>
                                    <option value="true">Sim</option>
                                    <option value="false">Não</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">Prazo Máximo</label>
                                <input class="form-control" type="date" @bind="prazo" disabled />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Tem descrição?</label>
                                <select class="form-select" id="temDescricao">
                                    <option selected disabled>Selecione</option>
                                    <option value="true">Sim</option>
                                    <option value="false">Não</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Descrição do Projeto</label>
                                <textarea class="form-control" @bind="descricao" rows="4" disabled></textarea>
                            </div>

                            <div class="col-12 d-flex justify-content-end pt-3">
                                <button class="btn btn-primary px-5" @onclick="AdicionarProjeto">
                                    Criar Projeto
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100 bg-white">

                    <div class="card-body p-4">

                        <h6 class="fw-bold text-dark mb-4 border-bottom pb-2">
                            <i class="bi bi-clock-history me-2 text-primary"></i>
                            Últimos Projetos
                        </h6>

                        <div class="d-flex flex-column gap-3">

                            <div class="d-flex align-items-center justify-content-between p-2 rounded hover-light">

                                <div class="d-flex align-items-center gap-3">

                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                         style="width:40px;height:40px;font-size:14px;">
                                        PG
                                    </div>

                                    <div>
                                        <div class="fw-semibold small text-dark">
                                            Projeto Golpe em Golpista
                                        </div>

                                        <div class="text-muted small">
                                            Wallace Falque
                                        </div>
                                    </div>

                                </div>

                                <div class="text-end">
                                    <span class="badge bg-danger-subtle text-danger small">
                                        Urgente
                                    </span>
                                    <div class="text-muted" style="font-size:11px;">
                                        Hoje
                                    </div>
                                </div>

                            </div>

                        </div>

                    </div>

                </div>
            </div>

            <div class="col-12 mb-5">
                <div class="card shadow-sm border-0 custom-card overflow-hidden">
                    <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold m-0 text-dark">
                            <i class="bi bi-kanban-fill text-primary pe-2"></i>Projetos
                        </h5>
                        <span class="badge bg-primary-subtle text-primary rounded-pill">@todosProjetos.Count</span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">ID</th>
                                    <th>Projeto</th>
                                    <th>Cliente</th>
                                    <th>Início</th>
                                    <th>Prazo</th>
                                    <th>Prioridade</th>
                                    <th>Progresso</th>
                                    <th class="text-end pe-4">Status</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var projeto in todosProjetos)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted">@projeto.Id</td>

                                        <td>
                                            <span class="fw-bold">@projeto.Nome</span>
                                        </td>

                                        <td>@projeto.DataInicio.ToShortDateString()</td>

                                        <td>@(projeto.Prazo?.ToShortDateString() ?? "-")</td>

                                        <td>
                                            <span class="badge bg-danger-subtle text-dark">
                                                @projeto.Prioridade
                                            </span>
                                        </td>

                                        <td style="min-width: 120px;">
                                            <div class="progress" style="height: 6px;">
                                                <div class="progress-bar bg-success" style="width: 75%"></div>
                                            </div>
                                        </td>

                                        <td class="text-end pe-4">
                                            <span class="badge bg-warning-subtle text-dark">
                                                EM BREVE
                                            </span>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td colspan="7" class="px-4 pb-3 pt-0">
                                            <div class="bg-light rounded p-3 small text-muted">
                                                @(string.IsNullOrWhiteSpace(projeto.Descricao)
                                                    ? "Sem descrição"
                                                    : projeto.Descricao)
                                            </div>
                                        </td>
                                    </tr>
                                }

                               
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

@code {
    List<Onboarding> todosProjetos = new();

    string novoOnboarding = "";
    PrioridadeOnboarding? prioridade = null;
    DateTime dataInicio = DateTime.Today;
    DateTime? prazo = DateTime.Today;
    string? descricao = "";

    protected override void OnInitialized()
    {
        todosProjetos = db.Onboardings.ToList();

    }

    void AdicionarProjeto()
    {
        if (string.IsNullOrWhiteSpace(novoOnboarding)) return;

        var onboarding = new Onboarding
        {
            Nome = novoOnboarding,
            DataInicio = dataInicio,
            Prioridade = prioridade,
            Descricao = descricao
        };

        db.Onboardings.Add(onboarding);
        db.SaveChanges();

        novoOnboarding = "";
        prioridade = null;
        dataInicio = DateTime.Today;
        prazo = DateTime.Today;
        descricao = "";

        todosProjetos = db.Onboardings.ToList();
    }
}
